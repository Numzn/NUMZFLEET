# ERB Fuel Monitor environment configuration
# Copy this file to .env and replace values.

# Email settings
EMAIL_ENABLED=true
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_TO=recipient@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Network/SSL settings
SSL_VERIFY=true
SSL_ALLOW_INSECURE_FALLBACK=true

# Optional S3 persistence
S3_ENABLED=false
S3_BUCKET=
S3_KEY=fuel_prices.json

# After each worker container start, scrape once and refresh data/fuel_prices.json for erb-api (default true).
ERB_STARTUP_REFRESH=true

# Lean monitor (Lusaka window; see README)
MONITOR_TZ=Africa/Lusaka
MONITOR_WINDOW_START=15:00
MONITOR_WINDOW_END_HOUR=0
MONITOR_POLL_MINUTES=10
MONITOR_MIN_DAY=25

# Public API settings
API_TOKEN=replace-with-long-random-token
API_ALLOWED_ORIGINS=https://your-frontend.example.com
