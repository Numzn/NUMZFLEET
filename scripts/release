#!/usr/bin/env bash
# Open a pull request from develop to main (production release).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "${ROOT}"

if ! command -v gh >/dev/null 2>&1; then
  echo "GitHub CLI (gh) is required. Install: https://cli.github.com/" >&2
  exit 1
fi

git fetch origin develop main

if ! git rev-parse --verify origin/develop >/dev/null 2>&1; then
  echo "origin/develop not found — push develop first: git push -u origin develop" >&2
  exit 1
fi

TITLE="${1:-Release: merge develop into main}"
BODY="${2:-Production release via develop → main PR. Merging triggers GitHub Actions deploy to OCI.}"

gh pr create \
  --base main \
  --head develop \
  --title "${TITLE}" \
  --body "${BODY}"

echo "PR created. Review and merge on GitHub to deploy production."
