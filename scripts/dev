#!/usr/bin/env bash
# Start NUMZFLEET development stack with hot reload on NumzLab.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
COMPOSE="${ROOT}/deployment/compose/docker-compose.dev.yml"
ENV_FILE="${ROOT}/deployment/.env.dev"
ENV_EXAMPLE="${ROOT}/deployment/.env.dev.example"

cd "${ROOT}"

if [[ ! -f "${ENV_FILE}" ]]; then
  if [[ -f "${ENV_EXAMPLE}" ]]; then
    cp "${ENV_EXAMPLE}" "${ENV_FILE}"
    echo "Created ${ENV_FILE} from example — review before production use."
  else
    echo "Missing ${ENV_FILE}. Copy from ${ENV_EXAMPLE}." >&2
    exit 1
  fi
fi

if [[ ! -f "${ROOT}/backend/.env" ]]; then
  echo "Missing ${ROOT}/backend/.env — required for DB credentials." >&2
  exit 1
fi

# Export backend secrets for compose variable substitution (DATABASE_URL, etc.)
set -a
# shellcheck disable=SC1091
source "${ROOT}/backend/.env"
set +a

# Stop staging stack if running (same host ports).
if docker ps --format '{{.Names}}' | grep -q '^numzfleet-staging-'; then
  echo "Stopping staging stack (port conflict)..."
  docker compose -f "${ROOT}/deployment/compose/docker-compose.staging.yml" \
    --env-file "${ROOT}/deployment/.env.staging" down 2>/dev/null || true
fi

# Ensure data volumes exist (reuse staging data).
for vol in numzfleet_staging_postgres_data numzfleet_staging_traccar_mysql_data numzfleet_staging_erb_data numzfleet_invoice_attachments; do
  docker volume inspect "$vol" >/dev/null 2>&1 || docker volume create "$vol" >/dev/null
done

echo "Starting NUMZFLEET dev stack..."
docker compose -f "${COMPOSE}" --env-file "${ENV_FILE}" up -d --build

echo ""
echo "Dev stack starting. UI: http://fleet.numzlab or http://127.0.0.1:3003"
echo "API: http://api.fleet.numzlab/health or http://127.0.0.1:3000/health"
echo "Logs: ./scripts/logs"
