# NumzTrak Frontend - Essential Environment Variables
# Copy this to .env (Vite automatically loads .env files)

# Traccar API + map WebSocket prefix. Production uses .env.production (/traccar).
# Leave empty locally if you rely on Vite proxy /api → Traccar for Traccar-only dev.
#VITE_TRACCAR_PREFIX=/traccar

# Application version (displayed in settings page)
VITE_APP_VERSION=

# With REMOTE_API_BASE_URL: fuel proxy defaults to http://localhost:3000 (root Compose service backend).
# Set VITE_FUEL_API_URL if fuel lives elsewhere, or VITE_FUEL_PROXY_USE_REMOTE=true to proxy fuel to the same remote base.
#VITE_FUEL_API_URL=http://localhost:3000
#VITE_FUEL_PROXY_USE_REMOTE=true

# Dev server port (optional; default 5174 so host :3002 can stay Docker static frontend).
#VITE_DEV_SERVER_PORT=5174
# Mobile on Wi‑Fi: set VITE_HMR_EXTERNAL to this PC’s LAN IP (e.g. 10.152.184.242). Leave blank on desktop —
# HMR then uses the same port as the HTTP server (avoids ws on the wrong port when you override VITE_DEV_SERVER_PORT).
VITE_HMR_EXTERNAL=
# Only when VITE_HMR_EXTERNAL is set; otherwise ignored.
#VITE_HMR_PORT=5174
#VITE_HMR_CLIENT_PORT=5174

# Mobile Fleet Command bottom sheet on /map (Sprint 1). On by default on mobile; desktop sidebar unchanged.
# Set to 0 to disable: VITE_FLEET_COMMAND_SHEET=0
