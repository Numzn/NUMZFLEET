# Dev PC → NumzLab (Phase 1)
# Copy to .env in this directory and replace NUMZLAB_IP:
#   cp .env.numzlab.example .env
#
# Do NOT set LOCAL_DEV=true (that targets localhost without SSH tunnel).

REMOTE_API_BASE_URL=http://NUMZLAB_IP:8082
VITE_FUEL_API_URL=http://NUMZLAB_IP:3000
VITE_DEV_SERVER_PORT=5174
VITE_HMR_EXTERNAL=
