# Optional overrides — copy to auto_deploy.env (gitignored). See auto_deploy.defaults.env and REGISTRY_DEPLOY.md.
# For target-specific templates, see:
#   auto_deploy.staging.env.example
#   auto_deploy.production.env.example

# NUMZFLEET_SSH_HOST=
# NUMZFLEET_SERVER_REPO_PATH=/home/ubuntu/NUMZFLEET  (omit line to use default; /opt/NUMZFLEET is remapped)
# NUMZFLEET_SSH_IDENTITY_FILE=~/.ssh/oci_instance_key.pem
# NUMZFLEET_DEPLOY_IMAGE_TAG=<full-sha-with-images>   # when HEAD is deployment-only and CI did not build
# NUMZFLEET_AUTO_DEPLOY_IMAGE_FROM_LAST_CI_COMMIT=0   # disable auto IMAGE_TAG from last app/CI commit (default: on)
# NUMZFLEET_POST_VERIFY=0
# NUMZFLEET_POST_VERIFY_WAIT_SECONDS=90
# NUMZFLEET_POST_VERIFY_ORIGIN=https://numz.site
# NUMZFLEET_AUTO_COMMIT_MESSAGE=0   # omit = auto commit message from staged paths when -m not passed
