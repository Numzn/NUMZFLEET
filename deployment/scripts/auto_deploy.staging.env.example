# Optional local overrides for: python deployment/scripts/auto_deploy.py --target staging
# Copy to deployment/scripts/auto_deploy.env (gitignored) or pass with:
#   NUMZFLEET_AUTO_DEPLOY_ENV_FILE=deployment/scripts/auto_deploy.staging.env

NUMZFLEET_BRANCH=develop
# Tailscale: homelab / numzlab (100.121.79.2). On LAN use 192.168.1.177 (homelab-lan).
NUMZFLEET_SSH_HOST=100.121.79.2
NUMZFLEET_SSH_USER=numz14
NUMZFLEET_SSH_IDENTITY_FILE=C:/Users/NUMERI/.ssh/id_ed25519
NUMZFLEET_SERVER_REPO_PATH=/srv/projects/numzfleet
NUMZFLEET_DEPLOY_ENV=deployment/.env.staging
NUMZFLEET_USE_MIGRATIONS=1

# Staging post-verify origin (if you want external probes from this workstation).
# NUMZFLEET_POST_VERIFY_ORIGIN=http://100.121.79.2:3003

# Optional: auto_deploy uses GITHUB_TOKEN to pick a SHA with successful CI image builds.
# RCC passes this from release-control-center/config/rcc.env when deploying from the UI.
# GITHUB_TOKEN=
# GITHUB_REPOSITORY=Numzn/NUMZFLEET
