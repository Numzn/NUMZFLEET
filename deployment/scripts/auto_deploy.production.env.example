# Optional local overrides for: python deployment/scripts/auto_deploy.py --target production --promoted-sha <sha>
# Copy to deployment/scripts/auto_deploy.env (gitignored) or pass with:
#   NUMZFLEET_AUTO_DEPLOY_ENV_FILE=deployment/scripts/auto_deploy.production.env

NUMZFLEET_BRANCH=main
NUMZFLEET_SSH_HOST=129.151.163.95
NUMZFLEET_SSH_USER=ubuntu
NUMZFLEET_SSH_IDENTITY_FILE=~/.ssh/oci_instance_key.pem
NUMZFLEET_SERVER_REPO_PATH=/home/ubuntu/NUMZFLEET
NUMZFLEET_DEPLOY_ENV=deployment/.env
NUMZFLEET_USE_MIGRATIONS=1

# Production post-verify from workstation.
NUMZFLEET_POST_VERIFY_ORIGIN=https://numz.site
# NUMZFLEET_POST_VERIFY_STRICT=1
