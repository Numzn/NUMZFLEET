# Copy to deployment/backup/backup.env on the server (or set BACKUP_ENV_FILE) and chmod 600.
# Sourced by run-backup.sh before backup.sh.

export COMPOSE_DIR=/home/ubuntu/numzfleet
# Match production if you use: docker compose -p <name> up
# export COMPOSE_PROJECT_NAME=numzfleet
# Match production compose files exactly (space-separated -f ... flags)
# export COMPOSE_ARGS_OVERRIDE="-f docker-compose.yml -f docker-compose.erb.yml"
# export ERB_VOLUME_NAME=numzfleet_erb_data
export SECRETS_FILE=/home/ubuntu/numzfleet/backup-secrets.env
export BACKUP_ROOT=/home/ubuntu/backups
export RETENTION_DAYS=14
export MIN_DUMP_BYTES=4096

# S3 upload (optional)
# export AWS_REGION=eu-frankfurt-1
# export S3_BUCKET=s3://your-bucket-name
# export S3_PREFIX=numzfleet/prod
# export DISABLE_S3_UPLOAD=0

# Optional failure notification (JSON body must stay secret-free)
# export BACKUP_WEBHOOK_URL=https://hooks.example.com/backup-alert

# Google Drive via rclone (optional). Configure rclone as the SAME user as cron (e.g. ~/.config/rclone/).
# export DRIVE_ENABLED=1
# export DRIVE_REMOTE=gdrive
# export DRIVE_PATH=optional/subfolder
# export DRIVE_RETENTION_DAYS=60
