# Copy to ${COMPOSE_DIR}/backup-secrets.env and: chmod 600 backup-secrets.env
# Values must match POSTGRES_PASSWORD and MYSQL_ROOT_PASSWORD in backend/.env
# (used by db and traccar-mysql via env_file).
#
# Use single-line values only (no quotes required for simple passwords).
# Rotating DB passwords: update BOTH backend/.env and this file.

POSTGRES_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
