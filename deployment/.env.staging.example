# Copy to deployment/.env.staging on NumzLab (gitignored in real usage).
# Used by deployment/deploy/deploy-to-staging.sh and docker compose --env-file.

# Registry provider for staging pull-only deploy.
REGISTRY_PROVIDER=dockerhub
DOCKERHUB_USERNAME=numz14
REGISTRY_PREFIX=numz14

# Required: immutable app image tag already built by CI.
IMAGE_TAG=replace-with-full-git-sha

# Staging-facing defaults (Tailscale + local Vite).
CORS_ORIGIN=http://100.121.79.2:3003,http://localhost:5174
AUTH_STRATEGY=hybrid
ERB_API_ALLOWED_ORIGINS=http://100.121.79.2:3003,http://localhost:5174

# Optional host port override for Postgres.
# POSTGRES_HOST_PORT=5433
