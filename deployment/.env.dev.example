# Copy to deployment/.env.dev on NumzLab (gitignored).
# Used by: docker compose -f deployment/compose/docker-compose.dev.yml --env-file deployment/.env.dev

# Dev-facing CORS — single source of truth for fuel-api (REST + Socket.IO).
# Browser Origin follows the host port in the URL (e.g. :3003), not Vite's internal :5174.
CORS_ORIGIN=http://fleet.numzlab,https://fleet.numzlab,http://api.fleet.numzlab,https://api.fleet.numzlab,http://100.121.79.2:3003,http://100.121.79.2:3000,http://localhost:3003,http://127.0.0.1:3003,http://localhost:3002,http://127.0.0.1:3002,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176
ERB_API_ALLOWED_ORIGINS=http://fleet.numzlab,https://fleet.numzlab,http://100.121.79.2:3003,http://localhost:3003,http://127.0.0.1:3003,http://localhost:5174

# Auth (dev-friendly defaults)
AUTH_STRATEGY=hybrid
DEV_AUTH_BYPASS=false

# Optional override for fuel-api → Traccar service account (immobilization, maintenance proxy).
# Default: backend/.env TRACCAR_API_USER / TRACCAR_API_PASSWORD via compose env_file.
# TRACCAR_API_USER=
# TRACCAR_API_PASSWORD=

# Host port for Postgres diagnostics
POSTGRES_HOST_PORT=5433

# Vite dev server (inside frontend container)
VITE_DEV_SERVER_PORT=5174
VITE_FUEL_API_URL=http://backend:3000
VITE_TRACCAR_URL=http://traccar:8082
# HMR through https://fleet.numzlab (TLS on :443). Comment out if you only use http://HOST:3003.
VITE_HMR_CLIENT_PORT=443
VITE_HMR_PROTOCOL=wss
