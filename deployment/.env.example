# Copy to deployment/.env and fill in values.
# Used by: deployment/push/push-images.sh, deployment/deploy/deploy-from-registry.sh

# dockerhub | ghcr
REGISTRY_PROVIDER=dockerhub

# Tag deployed by scripts (usually full git SHA)
IMAGE_TAG=replace-with-sha

# --- Docker Hub ---
DOCKERHUB_USERNAME=your-dockerhub-user

# --- GHCR ---
GHCR_OWNER=your-github-user-or-org

# Optional: deploy script sets REGISTRY_PREFIX from provider; override only if needed
# REGISTRY_PREFIX=your-dockerhub-user
