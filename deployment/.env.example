# Copy to deployment/.env on the server (gitignored). Used by:
#   deployment/deploy/deploy-from-registry.sh
#   deployment/push/push-images.sh
#   docker compose --env-file deployment/.env (variable substitution in docker-compose.prod.yml)

# --- Registry (production) ---
# dockerhub | ghcr
REGISTRY_PROVIDER=dockerhub

# Docker Hub namespace for numzfleet-* images (e.g. numz14 → numz14/numzfleet-frontend:SHA)
DOCKERHUB_USERNAME=numz14

# Image prefix for ${REGISTRY_PREFIX}/numzfleet-* in compose. deploy-from-registry.sh also sets this
# from DOCKERHUB_USERNAME when unset — but keep it here so plain `docker compose --env-file deployment/.env config` works.
REGISTRY_PREFIX=numz14

# Tag = immutable git SHA for deploy (scripts also accept SHA as CLI arg).
IMAGE_TAG=replace-with-full-git-sha

# --- GHCR (only if REGISTRY_PROVIDER=ghcr) ---
# GHCR_OWNER=your-github-user-or-org

# --- Compose interpolation (optional; defaults in compose) ---
# CORS_ORIGIN=https://your-frontend-host
# AUTH_STRATEGY=strict
# ERB_API_ALLOWED_ORIGINS=https://your-frontend-host
# ERB_EMAIL_ENABLED=false

# Secrets and DB URLs for app containers live in ../../backend/.env (see backend/env.template).

# Workstation-only deploy helper: scripts/auto_deploy*.env — see REGISTRY_DEPLOY.md (optional script).
