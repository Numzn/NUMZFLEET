# Copy to release-control-center/config/rcc.env (gitignored)
# Operator workstation — Dev PC with auto_deploy.py + SSH keys

# API auth (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
RCC_API_TOKEN=
RCC_ROLE=release-manager
# release-manager | operator | viewer

# Repo root (default: parent of release-control-center/)
NUMZFLEET_REPO_ROOT=

# GitHub (read runs for .github/workflows/main.yml)
GITHUB_TOKEN=
GITHUB_REPOSITORY=Numzn/NUMZFLEET

# Docker Hub (read tags / manifests)
DOCKERHUB_USERNAME=numz14
DOCKERHUB_TOKEN=

# NumzLab dev box (SSH read + health check only — not a deploy target)
# Match ~/.ssh/config Host: homelab | numzlab | homelab-lan (use LAN IP when on same network)
NUMZFLEET_SSH_HOST_NUMZLAB=100.121.79.2
NUMZFLEET_SSH_USER_NUMZLAB=numz14
NUMZFLEET_SSH_IDENTITY_NUMZLAB=C:/Users/NUMERI/.ssh/id_ed25519
NUMZFLEET_SERVER_REPO_NUMZLAB=/srv/projects/numzfleet
NUMZFLEET_NUMZLAB_HEALTH_ORIGIN=http://100.121.79.2

# OCI production (SSH read + rollback)
NUMZFLEET_SSH_HOST_PRODUCTION=129.151.163.95
NUMZFLEET_SSH_USER_PRODUCTION=ubuntu
NUMZFLEET_SSH_IDENTITY_PRODUCTION=~/.ssh/oci_instance_key.pem
NUMZFLEET_SERVER_REPO_PRODUCTION=/home/ubuntu/NUMZFLEET
NUMZFLEET_PRODUCTION_HEALTH_ORIGIN=https://numz.site

# auto_deploy env file (relative to repo root, break-glass path only)
AUTO_DEPLOY_ENV_PRODUCTION=deployment/scripts/auto_deploy.production.env

# Server
RCC_API_PORT=3011
RCC_UI_ORIGIN=http://127.0.0.1:5175

# Collector interval (seconds)
RCC_COLLECT_INTERVAL_SECONDS=60
