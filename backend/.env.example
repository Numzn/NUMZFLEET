# NumzTrak Fleet Management System - Environment Variables
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control!

# MySQL (Traccar Database)
# Default values shown below - CHANGE THESE IN PRODUCTION!
MYSQL_ROOT_PASSWORD=NumzTrak2025Root
MYSQL_DATABASE=traccar
MYSQL_USER=traccar
MYSQL_PASSWORD=traccar123

# PostgreSQL (Fuel API Database)
# Default value shown below - CHANGE THIS IN PRODUCTION!
POSTGRES_PASSWORD=NumzFuel2025

# Optional: explicit URL for fuel-api. If unset, fuel-api builds one from POSTGRES_PASSWORD
# (user=numztrak, host=db, port=5432, db=numztrak_fuel) — same contract as registry prod compose.
# DATABASE_URL=postgresql://numztrak:NumzFuel2025@db:5432/numztrak_fuel

# Application
NODE_ENV=development
CORS_ORIGIN=http://localhost:5174,http://localhost:3002
SESSION_SECRET=your_session_secret_here

# ERB Fuel Monitor API (shared secret between fuel-api and erb-api)
# fuel-api sends Authorization: Bearer <ERB_API_TOKEN> to erb-api /v1/prices/latest
# erb-api validates the same token via API_TOKEN
ERB_API_BASE_URL=http://erb-api:8000
ERB_API_TOKEN=replace-with-long-random-token
ERB_API_ALLOWED_ORIGINS=http://localhost:3002

# fuel-api (docker-compose.yml): default FUEL_API_NODE_ENV=development so permissive auth does not call process.exit(1).
# Production (deployment/compose/docker-compose.prod.yml): strict auth; POSTGRES_PASSWORD
# is enough for fuel-api DB URL unless you set DATABASE_URL above.
#   FUEL_API_NODE_ENV=production
#   AUTH_STRATEGY=strict
#   TRACCAR_ENABLED=true
# See deployment/REGISTRY_DEPLOY.md
FUEL_API_NODE_ENV=development
AUTH_STRATEGY=permissive
TRACCAR_ENABLED=true

# Vite HMR (Hot Module Replacement) - Frontend Development
VITE_HMR_EXTERNAL=
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5174
