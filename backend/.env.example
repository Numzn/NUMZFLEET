# NumzTrak Fleet Management System - Environment Template
# Copy this file to backend/.env and update with your actual values.
# DO NOT commit .env to version control!
#
# This is the single canonical env template (env.template was merged into it).
# Both compose stacks (root docker-compose.yml and deployment/compose/
# docker-compose.prod.yml) load backend/.env via env_file.

# ===========================================
# DATABASES
# ===========================================

# MySQL (Traccar database — the traccar-mysql container reads these directly).
# MYSQL_PASSWORD must match backend/conf/traccar.xml <entry key='database.password'>.
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=traccar
MYSQL_USER=traccar
MYSQL_PASSWORD=CHANGE_ME_STRONG_TRACCAR_DB_PASSWORD

# PostgreSQL (Fuel API database)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# Optional: explicit URL for fuel-api. If unset, fuel-api builds one from POSTGRES_PASSWORD
# (user=numztrak, host=db, port=5432, db=numztrak_fuel) — same contract as registry prod compose.
# DATABASE_URL=postgresql://numztrak:CHANGE_ME@db:5432/numztrak_fuel

# ===========================================
# APPLICATION
# ===========================================

# Dev default. Production (deployment/compose/docker-compose.prod.yml): NODE_ENV=production.
NODE_ENV=development
PORT=3000
# Dev origins shown; production example:
# CORS_ORIGIN=https://numz.site,https://app.numz.site
CORS_ORIGIN=http://localhost:5174,http://localhost:3002
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SESSION_SECRET

# fuel-api (docker-compose.yml): default FUEL_API_NODE_ENV=development so permissive auth does not call process.exit(1).
# Production (deployment/compose/docker-compose.prod.yml): strict auth; POSTGRES_PASSWORD
# is enough for fuel-api DB URL unless you set DATABASE_URL above.
#   FUEL_API_NODE_ENV=production
#   AUTH_STRATEGY=strict
#   TRACCAR_ENABLED=true
# See deployment/REGISTRY_DEPLOY.md
FUEL_API_NODE_ENV=development
AUTH_STRATEGY=permissive
TRACCAR_ENABLED=true

# Traccar HTTP service account (fuel-api — immobilization + Routine Service schedule sync).
# Set real values here or in project root .env; docker-compose passes TRACCAR_API_* into backend
# and overrides placeholder values in this file when root .env is present.
TRACCAR_SERVER_URL=http://traccar:8082
TRACCAR_API_USER=admin@example.com
TRACCAR_API_PASSWORD=change-me

# ===========================================
# ERB FUEL MONITOR
# ===========================================

# Shared secret between fuel-api and erb-api.
# fuel-api sends Authorization: Bearer <token> to erb-api /v1/prices/latest
# erb-api accepts API_TOKEN or ERB_API_TOKEN (same value — set at least one of each name to the same secret)
ERB_API_BASE_URL=http://erb-api:8000
ERB_API_TOKEN=replace-with-long-random-token
API_TOKEN=replace-with-long-random-token
# Dev origin shown; production: https://numz.site
ERB_API_ALLOWED_ORIGINS=http://localhost:3002

# ERB worker email notifications (compose maps ERB_EMAIL_* → the worker's EMAIL_* vars)
ERB_EMAIL_ENABLED=false
ERB_EMAIL_FROM=CHANGE_ME_EMAIL_SENDER
ERB_EMAIL_PASSWORD=CHANGE_ME_EMAIL_APP_PASSWORD
ERB_EMAIL_TO=CHANGE_ME_EMAIL_RECIPIENT
ERB_SMTP_SERVER=smtp.gmail.com
ERB_SMTP_PORT=587
ERB_SSL_VERIFY=true
ERB_SSL_ALLOW_INSECURE_FALLBACK=true

# Optional ERB S3 persistence
ERB_S3_ENABLED=false
ERB_S3_BUCKET=
ERB_S3_KEY=fuel_prices.json

# ===========================================
# DOCUMENT OCR
# ===========================================

# Document OCR (Python) — fuel-api calls document-ocr /v1/extract
# document-ocr validates Bearer token using DOCUMENT_OCR_TOKEN or API_TOKEN (must match fuel-api)
DOCUMENT_OCR_BASE_URL=http://document-ocr:8010
DOCUMENT_OCR_TOKEN=
DOCUMENT_OCR_ON_UPLOAD=1

# ===========================================
# SMS GATEWAY
# ===========================================

# NUMZ SMS Gateway (infrastructure/sms-gateway on NumzLab) — Dev-only path.
# fuel-api and the gateway are separate Docker networks on the same host, so
# SMS_GATEWAY_BASE_URL must be the discovered Docker bridge gateway IP
# (`docker network inspect bridge`), not a container name or 127.0.0.1.
# HTTP Basic Auth (not Bearer). Do NOT set these for OCI/production yet.
SMS_GATEWAY_BASE_URL=
SMS_GATEWAY_USER=
SMS_GATEWAY_PASSWORD=
SMS_GATEWAY_TIMEOUT_MS=10000

# ===========================================
# BACKGROUND JOBS
# ===========================================

# Immobilization intent evaluator tick (fuel-api). Default 2000ms; set 0 to disable.
# IMMOBILIZATION_EVALUATOR_INTERVAL_MS=2000
# IMMOBILIZATION_EVALUATOR_STARTUP_DELAY_MS=5000
# EXECUTION_CLAIM_TIMEOUT_SEC=45
# IMMOBILIZATION_RECONCILE_ON_STARTUP=1
# IMMOBILIZATION_USE_ADVISORY_LOCK=1
# IMMOBILIZATION_ACK_PROBE=1
# IMMOBILIZATION_ACK_PROBE_WINDOW_SEC=900

# Tracking notification bridge (poll Traccar tc_events → PostgreSQL notifications)
# Required for geofence/overspeed bell rows (PR1). Safe to re-run SQL migrations before enabling.
TRACKING_NOTIFICATION_BRIDGE=1
TRACKING_BRIDGE_POLL_MS=15000
# TRACKING_BRIDGE_BATCH_SIZE=100
# TRACKING_BRIDGE_LOOKBACK_HOURS=48

# ===========================================
# FRONTEND DEV
# ===========================================

# Vite HMR (Hot Module Replacement) - Frontend Development
VITE_HMR_EXTERNAL=
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5174

# GPS protocol ports are defined in backend/conf/traccar.xml and published on the
# host in deployment/compose/docker-compose.prod.yml (prod). Keep OCI ingress aligned
# with only the ports you use. Baseline keys: 5001–5006, 5009, 5013, 5020, 5055.
